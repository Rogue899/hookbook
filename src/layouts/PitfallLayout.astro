---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props { pitfall: CollectionEntry<'pitfalls'>; }
const { pitfall } = Astro.props;
const { data } = pitfall;

const severityColor: Record<string, string> = {
  low: 'bg-yellow-100 text-yellow-900',
  medium: 'bg-orange-100 text-orange-900',
  high: 'bg-red-100 text-red-900',
};
---
<BaseLayout title={`${data.title} — hookbook.dev`} description={data.description}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/pitfalls/">Pitfalls</a></nav>
    <div class="flex items-center gap-2 mb-2">
      <span class={`text-xs rounded px-2 py-0.5 ${severityColor[data.severity]}`}>severity: {data.severity}</span>
    </div>
    <h1 class="font-serif text-4xl mb-2">{data.title}</h1>
    <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">{data.description}</p>
    <div class="prose prose-neutral dark:prose-invert max-w-none"><slot /></div>
  </article>
</BaseLayout>
