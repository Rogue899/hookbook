---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props { pitfall: CollectionEntry<'pitfalls'>; }
const { pitfall } = Astro.props;
const { data } = pitfall;

const severityStyle: Record<string, string> = {
  low: 'background: var(--accent-soft); color: var(--trust-experimental);',
  medium: 'background: rgba(232,163,106,0.14); color: var(--trust-theoretical);',
  high: 'background: rgba(232,96,96,0.14); color: #E87070;',
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
    { '@type': 'ListItem', position: 2, name: 'Pitfalls', item: new URL('/pitfalls/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: data.title, item: new URL(`/pitfalls/${data.slug}/`, Astro.site).href },
  ],
};
---
<BaseLayout title={`${data.title} — hookbook.dev`} description={data.description} ogType="article">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />
  <article class="max-w-3xl mx-auto px-6 py-12">
    <nav class="text-sm mb-6" style="color: var(--muted);"><a href="/pitfalls/">Pitfalls</a></nav>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs rounded px-2 py-0.5" style={severityStyle[data.severity]}>severity: {data.severity}</span>
    </div>
    <h1 class="font-serif text-4xl mb-2">{data.title}</h1>
    <p class="text-lg mb-6" style="color: var(--ink-2);">{data.description}</p>
    <div class="prose max-w-none"><slot /></div>
  </article>
</BaseLayout>
