---
import BaseLayout from './BaseLayout.astro';
import TrustBadge from '../components/TrustBadge.svelte';
import CopyButton from '../components/CopyButton.svelte';
import type { CollectionEntry } from 'astro:content';

interface Props {
  recipe: CollectionEntry<'recipes'>;
  snippet?: string;
}

const { recipe, snippet = '' } = Astro.props;
const { data } = recipe;
---
<BaseLayout title={`${data.title} — hookbook.dev`} description={data.description} ogType="article">
  <article class="max-w-3xl mx-auto px-6 py-12">
    <nav class="text-sm mb-6" style="color: var(--muted);">
      <a href="/recipes/" class="hover:text-[var(--accent)]">Recipes</a>
      <span> / </span>
      <a href={`/recipes/${data.category}/`} class="hover:text-[var(--accent)]">{data.category}</a>
    </nav>

    <h1 class="font-serif text-4xl mb-2">{data.title}</h1>
    <p class="text-lg mb-4" style="color: var(--ink-2);">{data.description}</p>

    <div class="flex flex-wrap items-center gap-3 mb-6">
      <TrustBadge trust={data.trust} client:load />
      <span class="text-xs" style="color: var(--muted);">Event: <a href={`/events/${data.event.toLowerCase()}/`} class="underline">{data.event}</a></span>
      {data.matcher && <span class="text-xs" style="color: var(--muted);">Matcher: <code>{data.matcher}</code></span>}
      {data.hook_type && <span class="text-xs" style="color: var(--muted);">Type: <code>{data.hook_type}</code></span>}
    </div>

    {snippet && (
      <div class="relative my-6">
        <div class="absolute right-2 top-2">
          <CopyButton text={snippet} client:load />
        </div>
        <pre class="overflow-x-auto rounded p-4"><code>{snippet}</code></pre>
      </div>
    )}

    <div class="prose max-w-none">
      <slot />
    </div>

    {data.tested_on && data.tested_on.length > 0 && (
      <section class="mt-10 pt-6" style="border-top: 1px solid var(--rule);">
        <h2 class="font-serif text-xl mb-3">Tested on</h2>
        <ul class="space-y-2 text-sm">
          {data.tested_on.map((t) => (
            <li><strong>{t.date}</strong> — {t.sessions} sessions. {t.note}</li>
          ))}
        </ul>
      </section>
    )}

    {data.source && (
      <p class="mt-8 text-sm" style="color: var(--muted);">
        Source: {data.source_url ? <a href={data.source_url} class="underline">{data.source}</a> : data.source}
      </p>
    )}

    {data.contributor && (
      <p class="mt-2 text-sm" style="color: var(--muted);">Contributed by <a href={`https://github.com/${data.contributor}`} class="underline">@{data.contributor}</a></p>
    )}

    <footer class="mt-12 pt-6 text-sm" style="border-top: 1px solid var(--rule); color: var(--muted);">
      <a href={`https://github.com/Rogue899/hookbook/edit/main/src/content/recipes/${data.category}/${data.slug}.md`} class="underline">Edit this recipe on GitHub</a>
    </footer>
  </article>
</BaseLayout>
