---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props { event: CollectionEntry<'events'>; }
const { event } = Astro.props;
const { data } = event;

const allRecipes = await getCollection('recipes');
const matchingRecipes = allRecipes.filter((r) => r.data.event === data.name);
---
<BaseLayout title={`${data.name} hook event — hookbook.dev`} description={data.description}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <nav class="text-sm mb-6" style="color: var(--muted);">
      <a href="/events/" class="hover:text-[var(--accent)]">Events</a>
    </nav>

    <h1 class="font-serif text-4xl mb-2">{data.name}</h1>
    <p class="text-lg mb-6" style="color: var(--ink-2);">{data.description}</p>

    <section class="mb-8">
      <h2 class="font-serif text-xl mb-2">When it fires</h2>
      <p>{data.when_fires}</p>
    </section>

    {data.payload_fields && data.payload_fields.length > 0 && (
      <section class="mb-8">
        <h2 class="font-serif text-xl mb-2">Payload fields</h2>
        <ul class="list-disc pl-6">{data.payload_fields.map((f) => <li><code>{f}</code></li>)}</ul>
      </section>
    )}

    {data.common_matchers && data.common_matchers.length > 0 && (
      <section class="mb-8">
        <h2 class="font-serif text-xl mb-2">Common matchers</h2>
        <ul class="list-disc pl-6">{data.common_matchers.map((m) => <li><code>{m}</code></li>)}</ul>
      </section>
    )}

    {data.gotchas && data.gotchas.length > 0 && (
      <section class="mb-8">
        <h2 class="font-serif text-xl mb-2">Gotchas</h2>
        <ul class="list-disc pl-6">{data.gotchas.map((g) => <li>{g}</li>)}</ul>
      </section>
    )}

    <div class="prose max-w-none mb-8"><slot /></div>

    <section class="border-t pt-6">
      <h2 class="font-serif text-xl mb-4">Recipes that use this event</h2>
      {matchingRecipes.length === 0 ? (
        <p style="color: var(--muted);">No recipes yet — be the first to contribute one.</p>
      ) : (
        <ul class="space-y-2">
          {matchingRecipes.map((r) => (
            <li>
              <a href={`/recipes/${r.data.category}/${r.data.slug}/`} class="underline">{r.data.title}</a>
              <span class="text-xs ml-2" style="color: var(--muted);">({r.data.trust})</span>
            </li>
          ))}
        </ul>
      )}
    </section>
  </article>
</BaseLayout>
