---
const navItems = [
  { href: '/recipes/', label: 'Recipes' },
  { href: '/events/', label: 'Events' },
  { href: '/pitfalls/', label: 'Pitfalls' },
  { href: '/methodology/', label: 'Methodology' },
  { href: '/changelog/', label: 'Changelog' },
  { href: '/about/', label: 'About' },
];
const current = Astro.url.pathname;
---
<header class="border-b border-gray-200 dark:border-gray-800 sticky top-0 z-50 bg-white/90 dark:bg-gray-950/90 backdrop-blur">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="font-serif text-xl font-medium hover:text-[var(--color-accent)] transition-colors">hookbook.dev</a>
    <nav class="hidden sm:flex items-center gap-5 text-sm">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['hover:text-[var(--color-accent)] transition-colors', { 'text-[var(--color-accent)] font-medium': current.startsWith(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href="https://github.com/Rogue899/hookbook" rel="me noopener" class="text-sm hover:text-[var(--color-accent)]" aria-label="View source on GitHub">
      GitHub →
    </a>
  </div>
</header>
