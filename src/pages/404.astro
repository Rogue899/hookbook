---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found — hookbook.dev">
  <main class="max-w-2xl mx-auto px-6 py-24 text-center">
    <h1 class="font-serif text-5xl mb-3">404</h1>
    <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">That page doesn't exist. Try one of these:</p>
    <ul class="flex flex-wrap justify-center gap-4 text-sm">
      <li><a href="/" class="underline hover:text-[var(--color-accent)]">Home</a></li>
      <li><a href="/recipes/" class="underline hover:text-[var(--color-accent)]">All recipes</a></li>
      <li><a href="/events/" class="underline hover:text-[var(--color-accent)]">Events</a></li>
      <li><a href="/pitfalls/" class="underline hover:text-[var(--color-accent)]">Pitfalls</a></li>
    </ul>
  </main>
</BaseLayout>
